# Copy to .env.local for local dev, and set these in the Vercel dashboard for production.

# Database (Neon PostgreSQL)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
# In production set these to your deployed URL, e.g. https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Stripe (required for checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
